# ─────────────────────────────────────────────
# AgentRx — Local Development Environment
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git — it contains secrets.
# ─────────────────────────────────────────────

# Redis connection — points to the Redis container
# defined in docker-compose.yml. The hostname "redis"
# is the Docker service name, resolvable internally.
# Change to redis://localhost:6379/0 if running outside Docker.
AGENTRX_REDIS_URL=redis://redis:6379/0

# Comma-separated list of valid API keys for local dev.
# Generate a key: python -c "import secrets; print(secrets.token_urlsafe(32))"
AGENTRX_API_KEYS=dev_key_change_me_before_deploy

# How long agent failure history is kept in Redis (seconds).
AGENTRX_AGENT_STATE_TTL_SECONDS=3600

# How many execution steps before the circuit breaker fires.
AGENTRX_LOOP_DETECTION_THRESHOLD=20

# API rate limit per tenant per time window.
AGENTRX_RATE_LIMIT=60/minute

# Minimum confidence score below which we escalate to HUMAN_HANDOFF.
AGENTRX_MIN_AUTO_CONFIDENCE=0.70

# Environment label — appears in all JSON log entries.
AGENTRX_ENVIRONMENT=development

# Webhook URL for HUMAN_HANDOFF / AGENT_LOOP alerts.
# Leave empty to disable webhooks during local dev.
AGENTRX_WEBHOOK_URL=

# Seconds to wait for a webhook POST before timing out.
AGENTRX_WEBHOOK_TIMEOUT_SECONDS=5
